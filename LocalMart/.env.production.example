# ─────────────────────────────────────────────────────────────
#  LocalMart Next.js — Production Environment Variables
#  Copy to .env.production and fill in real values.
#  NEVER commit .env.production — it contains secrets.
#
#  In Vercel: paste each var into Project → Settings → Environment Variables
#  In Docker: pass via docker-compose env_file or --env-file flag
# ─────────────────────────────────────────────────────────────

# ── Supabase (public — safe in browser bundle) ───────────────
NEXT_PUBLIC_SUPABASE_URL=https://gpsmjadvqdcvoytkthjv.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Supabase (server-only — NEVER expose to client) ──────────
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret   # Settings → API → JWT Secret

# ── App URL (canonical, no trailing slash) ────────────────────
NEXT_PUBLIC_APP_URL=https://localmart.in

# ── Python Agent Backend ─────────────────────────────────────
# Internal docker network URL (used by Next.js API routes only)
AGENT_BACKEND_URL=http://agent-backend:8000
# Public WS URL (browser connects to this)
NEXT_PUBLIC_WS_URL=wss://localmart.in/ws/

# ── Anthropic AI ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Inter-service secrets ─────────────────────────────────────
AGENT_SERVICE_SECRET=change_me_32chars_random_hex
EXECUTION_WEBHOOK_SECRET=change_me_32chars_random_hex

# ── OAuth: social media tokens (managed by token_refresh.py) ─
# These are auto-refreshed and stored in Supabase oauth_tokens table.
# Set the initial values here; token_refresh.py rotates them.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_USER_TOKEN=       # Short-lived token from first OAuth login

INSTAGRAM_BUSINESS_ACCOUNT_ID=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ORGANIZATION_URN=urn:li:organization:XXXXXXX

# ── Email (SMTP via Resend / SendGrid) ───────────────────────
RESEND_API_KEY=re_...

# ── Twilio WhatsApp ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── CEO / Board access control ────────────────────────────────
